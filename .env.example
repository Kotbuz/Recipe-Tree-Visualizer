# Backend API
API_HOST=0.0.0.0
API_PORT=8000

# Logging (Loguru)
LOG_LEVEL=INFO
LOG_DIR=logs

# Storage
MODS_AUTO_LOAD_ON_STARTUP=true
MOD_UPLOAD_MAX_BYTES=268435456
MINECRAFT_VERSIONS_DIR=../MinecraftVersions
MINECRAFT_DEFAULT_VERSION=26.2
VERSION_CATALOG_CACHE_TTL_SECONDS=86400

# Icon renderer (Docker service renderer:3001)
RENDERER_URL=http://localhost:3001
RENDERER_MINECRAFT_ROOT=/data/minecraft
VANILLA_ICON_RENDER_ON_STARTUP=true

# JVM recipe export (Docker service recipe-exporter:8090, profile legacy-recipes)
# RECIPE_EXPORTER_URL=http://localhost:8090
# RECIPE_EXPORTER_MODE=auto
# RECIPE_EXPORTER_TIMEOUT_SECONDS=1800
# FORGE_JAVA_HOME=C:\Program Files\Eclipse Adoptium\jdk-8.0.492.9-hotspot

# Mod dependency resolver (CurseForge + Modrinth fallback)
# API key: https://console.curseforge.com/ → API Keys
CURSEFORGE_API_KEY=
CURSEFORGE_USER_AGENT=Recipe-Tree-Visualizer/1.0 (https://github.com/Kotbuz/Recipe-Tree-Visualizer)
# MOD_DEPENDENCY_DOWNLOAD_TIMEOUT_SECONDS=120

# CORS (comma-separated origins for dev server and Docker)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost

# Backend API
API_HOST=0.0.0.0
API_PORT=8000

# Logging (Loguru)
LOG_LEVEL=INFO
LOG_DIR=logs

# Storage
MODS_AUTO_LOAD_ON_STARTUP=true
MOD_UPLOAD_MAX_BYTES=268435456
MINECRAFT_VERSIONS_DIR=../MinecraftVersions
MINECRAFT_DEFAULT_VERSION=26.2
VERSION_CATALOG_CACHE_TTL_SECONDS=86400

# Icon renderer (Docker: http://renderer:3001; local: http://localhost:3001)
RENDERER_URL=http://localhost:3001
RENDERER_MINECRAFT_ROOT=/data/minecraft
VANILLA_ICON_RENDER_ON_STARTUP=true

# JVM recipe export (Docker: http://recipe-exporter:8090; local optional)
# RECIPE_EXPORTER_URL=http://localhost:8090
# RECIPE_EXPORTER_MODE=auto
# RECIPE_EXPORTER_TIMEOUT_SECONDS=1800
# NeoForge in-game export (Docker profile neo-recipes: http://recipe-exporter-neo:8091)
# NEO_RECIPE_EXPORTER_URL=http://localhost:8091
# NEO_RECIPE_EXPORTER_TIMEOUT_SECONDS=3600
# AUTO_BAKE_RECIPES_AFTER_INSTANCE_IMPORT=true
# FORGE_JAVA_HOME=C:\Program Files\Eclipse Adoptium\jdk-8.0.492.9-hotspot

# Mod dependency resolver (CurseForge + Modrinth fallback)
# API key: https://console.curseforge.com/ → API Keys
CURSEFORGE_API_KEY=
CURSEFORGE_USER_AGENT=Recipe-Tree-Visualizer/1.0 (https://github.com/Kotbuz/Recipe-Tree-Visualizer)
# MOD_DEPENDENCY_DOWNLOAD_TIMEOUT_SECONDS=120

# CORS (comma-separated origins for dev server and Docker)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost

# Путь к папке instances вашего лаунчера (Prism, MultiMC, CurseForge и т.д.)
# Нужен для проверки целостности и «Подтянуть недостающее», если бэкенд в Docker,
# а в профиле сохранён путь вида C:\Users\...\instances\Мой модпак.
#
# Локальный backend на Windows: можно оставить пустым — пути C:\... работают напрямую.
#
# Docker:
# 1) Укажите свой путь к папке instances (слэши / или \).
# 2) В docker-compose.yml раскомментируйте volume у сервиса backend.
INSTANCES_HOST_PATH=C:/Users/YOU/path/to/instances
# Точка монтирования внутри контейнера (должна совпадать с volume в docker-compose.yml)
INSTANCES_CONTAINER_PATH=/host/instances
# Явное сопоставление Windows → контейнер (необязательно, если задан INSTANCES_HOST_PATH):
# HOST_PATH_MAPPINGS=C:\Users\YOU\path\to\instances=/host/instances

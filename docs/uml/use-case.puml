@startuml use-case
!theme plain
skinparam shadowing false
skinparam defaultFontName Arial

title Use Case Diagram — Recipe Tree Visualizer

left to right direction

actor "Пользователь" as User
actor "DevOps" as DevOps

rectangle "Recipe Tree Visualizer" {
  usecase "UC1\nИмпорт .jar мода" as UC1
  usecase "UC2\nИмпорт модпака" as UC2
  usecase "UC3\nОбновить список модов\n(hot reload)" as UC3
  usecase "UC4\nПоиск предмета" as UC4
  usecase "UC5\nДобавить предмет\nна холст" as UC5
  usecase "UC6\nСоздать узел рецепта\n(связь от ингредиента)" as UC6
  usecase "UC7\nВыбрать альтернативный\nрецепт" as UC7
  usecase "UC8\nАвтопостроение\nцепочки" as UC8
  usecase "UC9\nРасчёт производительности\n(items/min, машины)" as UC9
  usecase "UC10\nВыравнивание графа\nна холсте" as UC10
  usecase "UC11\nПроверить API" as UC11
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6
User --> UC7
User --> UC8
User --> UC9
User --> UC10

DevOps --> UC11

UC1 ..> UC4 : <<include>>
UC2 ..> UC4 : <<include>>
UC4 ..> UC5 : <<include>>
UC5 ..> UC6 : <<extend>>
UC6 ..> UC7 : <<extend>>
UC5 ..> UC8 : <<extend>>
UC8 ..> UC9 : <<extend>>

note bottom of UC6
  Двудольный граф:
  Item -> Recipe -> Item
end note

note bottom of UC9
  Нормализация рецептов
  для расчёта, UI показывает
  оригинал из игры
end note

@enduml

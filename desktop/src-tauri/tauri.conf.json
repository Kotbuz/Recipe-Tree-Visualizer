{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "Recipe Tree Visualizer",
    "version":  "0.1.3",
    "identifier":  "com.rtv.desktop",
    "build":  {
                  "beforeDevCommand":  "npm run dev --prefix ../frontend",
                  "devUrl":  "http://localhost:5173",
                  "beforeBuildCommand":  "npm run build --prefix ../frontend",
                  "frontendDist":  "../../frontend/dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "Recipe Tree Visualizer",
                                    "width":  1440,
                                    "height":  900,
                                    "resizable":  true
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/icon.ico"
                            ]
               }
}

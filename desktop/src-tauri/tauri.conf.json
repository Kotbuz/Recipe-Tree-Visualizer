{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "Recipe Tree Visualizer",
    "version":  "0.2.4",
    "identifier":  "com.rtv.desktop",
    "build":  {
                  "beforeDevCommand":  "npm run dev --prefix ../frontend",
                  "devUrl":  "http://localhost:5173",
                  "beforeBuildCommand":  "npm run build --prefix ../frontend",
                  "frontendDist":  "../../frontend/dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "Recipe Tree Visualizer",
                                    "width":  1440,
                                    "height":  900,
                                    "resizable":  true
                                }
                            ],
                "security":  {
                                 "csp":  "default-src \u0027self\u0027 asset: http://asset.localhost https://asset.localhost; connect-src \u0027self\u0027 http://127.0.0.1:8000 http://localhost:8000 ipc: http://ipc.localhost https://tauri.localhost http://tauri.localhost https://asset.localhost http://asset.localhost; img-src \u0027self\u0027 asset: http://asset.localhost https://asset.localhost blob: data: http://127.0.0.1:8000 http://localhost:8000; style-src \u0027self\u0027 \u0027unsafe-inline\u0027"
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/icon.ico"
                            ],
                   "resources":  {
                                     "bin/backend-bundle/":  "backend-bundle/"
                                 }
               }
}

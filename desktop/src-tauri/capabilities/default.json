{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capabilities",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-spawn",
    "shell:allow-execute",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:8000" },
        { "url": "http://127.0.0.1:8000/**" },
        { "url": "http://127.0.0.1:*" },
        { "url": "http://localhost:8000/**" },
        { "url": "http://localhost:*" }
      ]
    }
  ]
}